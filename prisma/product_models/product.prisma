model Product {
    id           String    @id @default(cuid())
    title        String    
    description  String
    price        Decimal
    stock        Int

    modelUrl    String?

    createdByUserId  String
    CreatedByAdmin   User @relation(fields: [createdByUserId], references: [id])

    images      ProductImages[]

    createdAt      DateTime    @default(now())
    updatedAt      DateTime    @updatedAt
}