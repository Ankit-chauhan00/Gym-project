enum Role {
  USER
  ADMIN
  TRAINER
}

model User {
  id           String    @id @default(cuid())

  // Profile
  name         String?
  username     String?   @unique
  email        String    @unique
  image        String?

  // Authorization
  role         Role      @default(USER)

  // Credentials Auth
  password     String?

  // Relations
  accounts     Account[]
  products     Product[]

  trainerProfile Trainer?

  trainerConnections TrainerClient[]

  // Timestamps
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}