enum Role {
  USER
  ADMIN
  TRAINER
  DELIVERY_PARTNER
  DELIVERY_AGENT
}

model User {
  id           String    @id @default(cuid())

  // Profile
  name         String?
  username     String?   @unique
  email        String    @unique
  image        String?

  // Authorization
  role         Role      @default(USER)

  // Credentials Auth
  password     String?

  // Relations
  accounts     Account[]
  products     Product[]
  orders       Order[]

  assignedDeliveries    Order[] @relation("AssignedOrders")
  collectedPayments   Payment[] @relation("CollectedPayments")

  trainerProfile Trainer?

  trainerConnections TrainerClient[]

  cart         Cart[]
  // Timestamps
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}